{
    "name": "nidhinnp/microblink-id-image-upload",
    "version": "1.0.0",
    "description": "Laravel package for uploading ID/document images to Microblink API",
    "keywords": [
        "laravel",
        "microblink",
        "id-verification",
        "document-upload",
        "image-upload",
        "kyc"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Nidhinnp",
            "email": "0143nidhinnp@gmail.com"
        }
    ],
    "require": {
        "php": "^8.0",
        "guzzlehttp/guzzle": "^7.0",
        "illuminate/support": "^9.0|^10.0|^11.0|^12.0",
        "illuminate/http": "^9.0|^10.0|^11.0|^12.0",
        "illuminate/config": "^9.0|^10.0|^11.0|^12.0",
        "illuminate/routing": "^9.0|^10.0|^11.0|^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^7.0|^8.0|^9.0",
        "phpunit/phpunit": "^9.0|^10.0"
    },
    "autoload": {
        "psr-4": {
            "Microblink\\IdImageUpload\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Microblink\\IdImageUpload\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Microblink\\IdImageUpload\\MicroblinkImageUploadServiceProvider"
            ],
            "aliases": {
                "MicroblinkUploader": "Microblink\\IdImageUpload\\Facades\\MicroblinkUploader"
            }
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}